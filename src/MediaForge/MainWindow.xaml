<Window x:Class="MediaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MediaForge.Core.Models;assembly=MediaForge.Core"
        Title="MediaForge"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File"/>
            <MenuItem Header="_Tools"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
        <ToolBar>

        <Button Content="Open"
                Command="{Binding OpenCommand}"
                IsEnabled="{Binding IsConverting, Converter={StaticResource InverseBooleanConverter}}" />

        <Button Content="Convert"
                Command="{Binding ConvertCommand}"
                IsEnabled="{Binding IsConverting, Converter={StaticResource InverseBooleanConverter}}" />
        
        <Button
            Content="Pause"
            Width="100"
            Margin="10,0,0,0"
            Command="{Binding PauseConversionCommand}"
            IsEnabled="{Binding IsConverting}" />

        <Button
            Content="Resume"
            Width="100"
            Margin="10,0,0,0"
            Command="{Binding ResumeConversionCommand}"
            IsEnabled="{Binding IsPaused}" />

        <Button
            Content="Cancel"
            Width="100"
            Margin="10,0,0,0"
            Command="{Binding CancelConversionCommand}"
            IsEnabled="{Binding IsConverting}" />

        <Button
            Content="Convert All"
            Command="{Binding ConvertCommand}"
            IsEnabled="{Binding IsConverting, Converter={StaticResource InverseBooleanConverter}}" />

        <Button Content="Remove"
                Command="{Binding RemoveSelectedCommand}" />

        <Button Content="⤒"
                Width="40"
                Command="{Binding MoveToTopCommand}" />

        <Button Content="▲"
                Width="40"
                Command="{Binding MoveUpCommand}" />

        <Button Content="▼"
                Width="40"
                Command="{Binding MoveDownCommand}" />

        <Button Content="⤓"
                Width="40"
                Command="{Binding MoveToBottomCommand}" />

        <Button Content="Remove Completed"
                Command="{Binding RemoveCompletedCommand}" />

        <Button Content="Retry Failed"
                Command="{Binding RetryFailedCommand}" />

        <Button Content="Clear Queue"
                Command="{Binding ClearQueueCommand}" />

        </ToolBar>
        </ToolBarTray>

        <!-- Status -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding Status}" />
        </StatusBar>

        <!-- Main Content -->
        <!-- Main Content -->
            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <GroupBox Header="File Information">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <Grid Margin="10">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="File"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FileName}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1"
                                   Text="Path"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding FullPath}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2"
                                   Text="Size"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding FileSize}"/>

                        <TextBlock Grid.Row="3"
                                   Text="Container"/>
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding Container}"/>

                        <TextBlock Grid.Row="4"
                                   Text="Resolution"/>
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding Resolution}"/>

                        <TextBlock Grid.Row="5"
                                   Text="Duration"/>
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   Text="{Binding Duration}"/>

                        <TextBlock Grid.Row="6"
                                   Text="Video Codec"/>
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Text="{Binding VideoCodec}"/>

                        <TextBlock Grid.Row="7"
                                   Text="Audio Codec"/>
                        <TextBlock Grid.Row="7"
                                   Grid.Column="1"
                                   Text="{Binding AudioCodec}"/>

                        <TextBlock Grid.Row="8"
                                   Text="Frame Rate"/>
                        <TextBlock Grid.Row="8"
                                   Grid.Column="1"
                                   Text="{Binding Fps}"/>

                        <TextBlock Grid.Row="9"
                                   Text="Bitrate"/>
                        <TextBlock Grid.Row="9"
                                   Grid.Column="1"
                                   Text="{Binding Bitrate}"/>

                        <TextBlock Grid.Row="10"
                                   Text="Status"/>
                        <TextBlock Grid.Row="10"
                                   Grid.Column="1"
                                   Text="{Binding Status}"/>
                                   
                        <TextBlock Grid.Row="11"
                                Text="Output"/>

                        <ComboBox Grid.Row="11"
                                Grid.Column="1"
                                Width="150"
                                ItemsSource="{Binding AvailableOutputFormats}"
                                SelectedItem="{Binding SelectedOutputFormat}"
                                DisplayMemberPath="Name"/>

                        <TextBlock Grid.Row="12"
                                Text="Trim Start"/>

                        <TextBox Grid.Row="12"
                                Grid.Column="1"
                                Width="120"
                                Text="{Binding SelectedQueueItem.TrimStart,
                                                UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="13"
                                Text="Trim End"/>

                        <TextBox Grid.Row="13"
                                Grid.Column="1"
                                Width="120"
                                Text="{Binding SelectedQueueItem.TrimEnd,
                                                UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="14"
                                Text="Compression"/>

                        <ComboBox Grid.Row="14"
                                Grid.Column="1"
                                Width="180"
                                ItemsSource="{Binding CompressionPresets}"
                                SelectedItem="{Binding SelectedQueueItem.CompressionPreset,
                                                        Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="15"
                                Text="Progress"/>

                        <ProgressBar Grid.Row="15"
                                    Grid.Column="1"
                                    Height="20"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="{Binding Progress}"/>

                        <TextBlock Grid.Row="15"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding ProgressText}"/>

                    </Grid>

                </ScrollViewer>

            </GroupBox>

            <!-- Drop Zone -->
            <Border Grid.Column="2"
        BorderBrush="Gray"
        BorderThickness="2"
        Background="Transparent">

    <Grid Background="Transparent"
      AllowDrop="True"
      DragEnter="DropZone_DragEnter"
      DragOver="DropZone_DragOver"
      Drop="DropZone_Drop">

    <Image Source="{Binding PreviewImage}"
           Stretch="Uniform"
           Margin="10"
           IsHitTestVisible="False"/>

    <TextBlock x:Name="DropMessage"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="22"
               TextAlignment="Center"
               IsHitTestVisible="False"
               Text="Drop Media Here&#10;&#10;or&#10;&#10;Click Open"/>
</Grid>

</Border>
            <GroupBox Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Margin="0,10,0,0"
                    Header="Conversion Queue">

                <DataGrid ItemsSource="{Binding ConversionQueue}"
                        SelectedItem="{Binding SelectedQueueItem}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="File"
                            Binding="{Binding Media.FileName}"
                            Width="*" />

                        <DataGridTextColumn
                            Header="Output"
                            Binding="{Binding OutputFormat.Name}"
                            Width="120"/>

                         <DataGridTextColumn
                            Header="Trim Start"
                            Binding="{Binding TrimStart}"
                            Width="110"/>

                        <DataGridTextColumn
                            Header="Trim End"
                            Binding="{Binding TrimEnd}"
                            Width="110"/>

                        <DataGridTextColumn
                            Header="Status"
                            Binding="{Binding Status}"
                            Width="120"/>

                        <DataGridTextColumn
                            Header="Progress"
                            Binding="{Binding Progress}"
                            Width="90"/>

                    </DataGrid.Columns>

                </DataGrid>

            </GroupBox>

        </Grid>

    </DockPanel>

</Window>